# ── Required ────────────────────────────────────────────────────────────────
# Azure Postgres (same DB the backend uses). Fetch it with:
#   az keyvault secret show --vault-name quizzical-shared-kv --name database-url --query value -o tsv
# SQLAlchemy-style schemes (postgresql+psycopg://...) are normalized automatically.
DATABASE_URL=

# OpenAI — generation (gpt-4o-mini), judging (gpt-4o), embeddings.
#   az keyvault secret show --vault-name quizzical-shared-kv --name openai-api-key --query value -o tsv
OPENAI_API_KEY=

# ── X / Twitter (OAuth 1.0a user context) ───────────────────────────────────
# LEAVE EMPTY until the owner creates the X developer app (see README
# "FOR THE OWNER"). While any of these four are missing the bot is ALWAYS in
# dry-run: it generates, judges, stores and logs — but posts nothing.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# App-only bearer token — ONLY needed for reply discovery via recent search,
# which requires the paid Basic tier (~$200/mo). Optional.
X_BEARER_TOKEN=

# ── Optional knobs (defaults shown) ─────────────────────────────────────────
# Force dry-run even when all X keys are present.
#SOCIAL_DRY_RUN=true
# Search provider: auto | x | fixture | none  (auto: x if bearer+enabled, else fixture if set, else none)
#SOCIAL_SEARCH_MODE=auto
# Explicit opt-in for paid recent search (needs X_BEARER_TOKEN + Basic tier).
#SOCIAL_X_SEARCH_ENABLED=false
# JSON file of tweets for demoing the reply pipeline without search access.
#SOCIAL_FIXTURE_PATH=fixtures/fake_tweets.json
# Current-events flavored posts via OpenAI web search (always-on flavoring;
# in posts-only/no-search mode ~1/3 of posts are trend-flavored regardless).
#SOCIAL_EVENTS_ENABLED=false
# Trend-led reply discovery (web-search probe each reply cycle). On by
# default; set false to make reply discovery topic-led only.
#SOCIAL_REPLY_TRENDS_ENABLED=true
# Public site + live API (defaults point at production).
#SOCIAL_SITE_BASE=https://quafel.com
#SOCIAL_API_BASE=https://api-quizzical-dev.whitesea-815b33ea.westus2.azurecontainerapps.io
# Models.
#SOCIAL_GEN_MODEL=gpt-4o-mini
#SOCIAL_JUDGE_MODEL=gpt-4o
#SOCIAL_EMBED_MODEL=text-embedding-3-small
