# =============================================================================
# Application Environment
# =============================================================================
APP_ENVIRONMENT="local"

# To use Azure for configuration, uncomment and set these endpoints.
# APP_CONFIG_ENDPOINT="your_azure_app_config_endpoint"
# AZURE_KEY_VAULT_ENDPOINT="your_azure_key_vault_endpoint"

# =============================================================================
# Secret Keys (replace with your actual keys for development)
# =============================================================================
SECRET_KEY="a_very_secret_key_for_local_development"
DATABASE_PASSWORD="postgres"          # Default Postgres password from docker-compose.yml

# --- LLM provider ---------------------------------------------------------
# Quizzical targets Google Gemini via LiteLLM (model strings: "gemini/gemini-2.5-flash").
GEMINI_API_KEY="your_gemini_api_key"
# OPENAI_API_KEY is optional; only needed if you swap any tool back to an OpenAI model.
OPENAI_API_KEY=""

# --- Cloudflare Turnstile -------------------------------------------------
TURNSTILE_SITE_KEY="your_turnstile_site_key"
TURNSTILE_SECRET_KEY="your_turnstile_secret_key"
ENABLE_TURNSTILE=False

# --- Other (optional) -----------------------------------------------------
FAL_AI_KEY="your_fal_ai_key"
GROQ_API_KEY="your_groq_api_key"

# =============================================================================
# Frontend Content (local overrides)
# =============================================================================
FRONTEND__CONTENT__APPNAME="Quizzical"

# =============================================================================
# Database and Redis Settings
#   - Defaults target the host machine. docker-compose overrides DATABASE__HOST=db
#     and REDIS__HOST=redis at runtime.
#   - DATABASE_URL (single underscore) takes precedence over the components below
#     if you set it explicitly.
# =============================================================================
DATABASE__HOST="localhost"
DATABASE__PORT=5432
DATABASE__USER="postgres"
DATABASE__DB_NAME="quiz"
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quiz

REDIS__HOST="localhost"
REDIS__PORT=6379
REDIS__DB=0

# =============================================================================
# Project Settings
# =============================================================================
PROJECT__NAME="Quizzical"
PROJECT__API_PREFIX="/api/v1"

# =============================================================================
# Agent and LLM Settings
# =============================================================================
AGENT__MAX_RETRIES=3
DEFAULT_LLM_MODEL="gemini/gemini-2.5-flash"

# Embedding model configuration for local HuggingFace usage
EMBEDDING__MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING__DIM=384
EMBEDDING__DISTANCE_METRIC="cosine"
EMBEDDING__COLUMN="synopsis_embedding"

# =============================================================================
# CORS
#   ALLOWED_ORIGINS accepts a JSON array. The backend reads this directly
#   in app/main.py (see _read_allowed_origins).
# =============================================================================
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]