ng, creating, and trying to define what truly matters to you.\\\",\\\\n  \\\"image_url\\\": null\\\\n}', annotations=[])], phase=None)], 'parallel_tool_calls': False, 'temperature': 0.0, 'tool_choice': 'auto', 'tools': [], 'top_p': None, 'max_output_tokens': None, 'previous_response_id': None, 'reasoning': None, 'status': 'completed', 'text': {}, 'truncation': None, 'usage': ResponseAPIUsage(input_tokens=225, input_tokens_details=InputTokensDetails(audio_tokens=None, cached_tokens=0, text_tokens=225), output_tokens=1126, output_tokens_details=OutputTokensDetails(reasoning_tokens=749, text_tokens=377), total_tokens=1351, cost=None), 'user': None, 'store': None}, 'event': 'llm.raw_response.received', 'level': 'info', 'logger': 'app.services.llm_service', 'timestamp': '2026-05-05T15:30:36.549548Z'}\\\">\", \"_from_structlog\": true}"}
