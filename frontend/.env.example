# ------------------------------------------------------------------
# Quizzical.ai Frontend Environment Variables
# Copy this file to .env (or .env.local) for local development.
# ------------------------------------------------------------------

# Backend API base URL.
#   - Host-machine dev (npm run dev):     http://localhost:8000/api/v1
#   - Same-origin dev / e2e:              /api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Cloudflare Turnstile test/dev keys (always pass).
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
VITE_TURNSTILE_DEV_MODE=true

VITE_USE_DB_RESULTS=false

# Set to 'true' to bypass the live /config endpoint and use src/mocks/configMock.
# VITE_USE_MOCK_CONFIG=true